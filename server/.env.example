PORT=3040
# Demo customer-care number shown when copilot marks [[UNCERTAIN]] (must match policy copy if you change it).
DEMO_CARE_PHONE=1800-200-1234
# Policy snippets retrieved per question (4–10; default 6).
# RAG_TOP_K=6
# Origin used in resume links returned by POST /api/resume/token
WEB_PUBLIC_ORIGIN=http://localhost:5174
RESUME_JWT_SECRET=change-me-to-a-long-random-string-for-demo
RESUME_TOKEN_TTL_MINUTES=120
# Primary LLM — Google Gemini (AI Studio key). GOOGLE_API_KEY also accepted.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Optional: Vertex or custom endpoint base (default: Google AI Studio REST)
# GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta

# Max **completion** tokens for OpenAI-compatible chat (LM Studio / OpenAI). Too low = answers cut mid-sentence.
# Default in code is 24576 if unset. LM Studio may also cap output in the local server UI — raise both if needed.
OPENAI_COMPAT_MAX_TOKENS=32768
# Gemini output cap (raise if long answers truncate).
# GEMINI_MAX_OUTPUT_TOKENS=8192

# Optional: LM Studio (OpenAI-compatible). When enabled, used after Gemini errors (e.g. 429) or as primary if no Gemini key.
# In LM Studio: load google/gemma-4-e4b, start Local Server; set LM_STUDIO_MODEL to the exact id shown in LM Studio.
LM_STUDIO_ENABLED=1
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
LM_STUDIO_MODEL=google/gemma-4-e4b
# LM_STUDIO_API_KEY=lm-studio

# Optional fallback — OpenAI-compatible cloud (used if Gemini fails and LM Studio is off or unreachable)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini
